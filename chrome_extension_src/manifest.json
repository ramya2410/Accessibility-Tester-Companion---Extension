{
  "manifest_version": 3,
  "name": "A11yTester Companion",
  "version": "1.1.0",
  "description": "Live ARIA APG hover checklist helper for accessibility manual testers.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}